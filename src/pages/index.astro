---
import Layout from "../layouts/Layout.astro";
import Assessment from "../components/Assessment";
import { SERVICES, BOOK_URL, LINE_URL, MAP_URL, ADDRESS, TRAINING_FORM_URL, SOCIAL } from "../data/services";

const voices = [
  { tag: "個人頌缽", text: "一開始足缽和銅鑼的時候，感覺之前膝蓋舊傷有點不舒服，我很意外，因為很久沒發作了。後面那個不舒服慢慢就流掉了。缽在身上磨，好舒服，震動震到身體很裡面。身體越來越鬆，突然被自己的打呼聲嚇醒，太舒服太感謝老師了！" },
  { tag: "個人頌缽", text: "這是我第一次體驗頌缽，本來以為會睡著，但我沒有。一開始思緒很混亂，透過一次次的缽聲把我帶回當下，我才意識到頭腦多麼 overload。慢慢那些訊息我完全沒印象了，也不重要了。我沒想過，專注自己是這麼爽的一件事！" },
  { tag: "雙人頌缽", text: "我以為我沒睡著，都有聽到老師敲缽，但我老婆說我打呼很大聲。我本來不太好睡，那天回家很快就睡著，隔天居然沒聽到鬧鐘聲。後來精神好很多，開會也比較專注，謝謝蕙如，下個月會再回訪。" },
  { tag: "團體頌缽", text: "本來只是好奇想讓自己休息一下，沒想到不只一下（笑）。那個聲音從耳朵慢慢進到身體裡，有點麻麻的，好像有什麼被輕輕梳理，不知不覺就睡著了。醒來後肩膀放鬆了、呼吸變深，整個人變得很輕、很有精神。" },
  { tag: "希塔療癒", text: "謝謝蕙如老師溫暖的引導，讓我看到小時候和媽媽的關係——那個為了討媽媽喜歡而不停逞強、不允許放鬆的自己。默默眼淚就掉了下來，那一刻我知道我終於擁抱到內在那個小女孩，胸口那塊石頭終於瓦解。" },
  { tag: "希塔療癒", text: "做完當下沒什麼特別感覺，但默默生活有好多變化——我不再執著那些讓自己不舒服的關係，也開始踏出舒適圈。這是我第三次來，謝謝蕙如伴著我成長。" },
];

const skills = ["尼泊爾傳統頌缽聲療", "歐美聲音療癒", "身心放鬆帶領", "臼井靈氣療癒", "冥想引導"];

const faqs = [
  { q: "需要穿什麼服裝？", a: "建議穿著舒適、放鬆的服裝即可。過程中多以躺姿或坐姿進行，讓身體能自在放鬆最重要。" },
  { q: "需要特別準備什麼嗎？", a: "不需要特別準備。體驗前可避免過度飲酒或空腹，並預留一些時間讓自己放慢步調，帶著輕鬆的心情前來即可。若近期有身體不適、懷孕、重大手術或特殊狀況，歡迎事先告知，一起評估最適合你的方式。" },
  { q: "孕婦可以參加嗎？", a: "懷孕期間是否適合，會依孕期狀況與服務內容有所不同。建議預約前先與我們聯繫討論，再依你的情況提供適合的建議。" },
  { q: "遲到怎麼辦？", a: "為了讓每位來訪者擁有完整的體驗時間，建議準時抵達。若臨時遇到狀況歡迎提前告知；若遲到較久，可能需依當日預約安排調整服務時間，以不影響下一位來訪者為原則。" },
  { q: "體驗過程中會睡著嗎？", a: "非常有可能 ☺️ 許多人放鬆後會自然進入休息或半睡半醒的狀態，這是很正常的反應。無論清醒或睡著，都不會影響體驗的進行。" },
  { q: "不知道自己適合哪一項怎麼辦？", a: "沒關係，這是很常見的問題。你可以先做上面的 3 分鐘自評，或透過 LINE 跟我聊聊近期的身心狀態，我會依你的需求協助推薦適合的服務。" },
];
---

<Layout>
  <!-- HERO -->
  <header class="hero">
    <img class="bg" src="/photos/hero1.jpg" alt="有我在療癒所 頌缽空間" />
    <div class="scrim"></div>
    <div class="inner">
      <div class="brand latin">I'm here</div>
      <div class="zh">有我在療癒所</div>
      <p class="tag">給忙碌生活中的你，<br />一段被好好照顧的時間。</p>
      <div class="cta">
        <a class="btn btn-pri" href="#assess">3 分鐘，找到適合我的療癒</a>
        <a class="btn btn-ghost" href={BOOK_URL} target="_blank" rel="noopener">立即預約</a>
      </div>
    </div>
  </header>

  <!-- 自評 -->
  <section id="assess" class="sec">
    <div class="wrap center">
      <span class="eyebrow">最近的你？</span>
      <h2 class="sec-title">先聽聽你的身體，<br />想被怎麼照顧</h2>
      <p class="lead">拉動下面 5 個感受，看看此刻最適合你的療癒方式。沒有對錯，只是陪你停下來、感覺自己。</p>
      <Assessment client:load />
    </div>
  </section>

  <!-- 服務 -->
  <section id="services" class="sec">
    <div class="wrap">
      <div class="center">
        <span class="eyebrow">Treatments</span>
        <h2 class="sec-title">三種陪伴身心的方式</h2>
      </div>
      <div class="svc-grid">
        {SERVICES.map((s) => (
          <article class="svc">
            <div class="ph"><img src={s.photo} alt={s.name} loading="lazy" /></div>
            <div class="body">
              <h3>{s.emoji} {s.name}</h3>
              <p class="desc">{s.desc}</p>
              <ul class="fit">{s.fit.map((f) => <li>{f}</li>)}</ul>
              <div class="meta">
                <div>🕐 {s.time}</div>
                <div class="price">{s.price}</div>
                <a class="btn btn-pri" href={BOOK_URL} target="_blank" rel="noopener">預約 {s.name}</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 專業音療師培訓 -->
  <section id="training" class="sec">
    <div class="wrap center">
      <span class="eyebrow">Training</span>
      <h2 class="sec-title">專業音療師培訓</h2>
      <p class="lead">
        想把頌缽聲療從一次體驗，走成一門能陪伴他人的專業？這套培訓陪你從聲音的原理、缽的操作到帶領實務，一步步成為能獨立帶領的音療師。
        <!-- TODO 慢慢補：課程大綱、適合對象、上課時數、費用、開課梯次 -->
      </p>
      <div class="cta">
        <a class="btn btn-pri" href={TRAINING_FORM_URL} target="_blank" rel="noopener">我要報名 / 索取課程資訊</a>
      </div>
    </div>
  </section>

  <!-- 主題活動 -->
  <section id="events" class="sec">
    <div class="wrap center">
      <span class="eyebrow">Events</span>
      <h2 class="sec-title">主題活動</h2>
      <p class="lead">
        不定期推出的團體聲浴、節氣靜心與主題療癒場次，和大家一起在聲音裡好好休息。
        <!-- TODO 慢慢補：近期場次（日期／主題／名額／報名方式） -->
      </p>
      <div class="cta">
        <a class="btn btn-ghost" href={LINE_URL} target="_blank" rel="noopener">關注近期場次（LINE）</a>
      </div>
    </div>
  </section>

  <!-- 客人回饋 -->
  <section id="voice" class="sec">
    <div class="wrap">
      <div class="center">
        <span class="eyebrow">Voices</span>
        <h2 class="sec-title">他們在這裡，<br />重新好好呼吸</h2>
      </div>
      <div class="voice-grid">
        {voices.map((v) => (
          <div class="quote">
            <div class="tag">🤍 {v.tag}</div>
            <p>{v.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 蕙如自介 -->
  <section id="about" class="sec">
    <div class="wrap">
      <div class="about">
        <div class="ph"><img src="/photos/owner.jpg" alt="蕙如老師" loading="lazy" /></div>
        <div>
          <span class="eyebrow">About</span>
          <h2>蕙如 ｜ Here</h2>
          <div class="role">聲音療癒師 · 身心放鬆帶領者</div>
          <div class="skills">{skills.map((s) => <span>{s}</span>)}</div>
          <p class="stat">累積服務超過 1,000 人次</p>
          <p>曾任職大型企業超過 10 年，因親身經歷身心失衡而踏上療癒之路。2024 年於桃園大園成立「有我在療癒所」，陪伴許多人在忙碌的生活中，重新找回放鬆與內在平衡。</p>
          <p>授課與合作經驗：企業員工紓壓活動、瑜珈空間與靜心課程合作、親子與兒童聲音療癒、公益頌缽與社區推廣。希望透過聲音與陪伴，讓每個人都能在忙碌生活中，找到屬於自己的安定與平衡。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="sec">
    <div class="wrap">
      <div class="center">
        <span class="eyebrow">FAQ</span>
        <h2 class="sec-title">預約前，你可能想知道</h2>
      </div>
      <div class="faq">
        {faqs.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <div class="ans">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- footer -->
  <footer class="foot">
    <div class="wrap">
      <div class="brand latin">I'm here</div>
      <div class="zh">有我在療癒所 · since 2024</div>
      {(SOCIAL.instagram || SOCIAL.facebook || SOCIAL.threads) && (
        <div class="social">
          {SOCIAL.instagram && <a href={SOCIAL.instagram} target="_blank" rel="noopener">Instagram</a>}
          {SOCIAL.facebook  && <a href={SOCIAL.facebook}  target="_blank" rel="noopener">Facebook</a>}
          {SOCIAL.threads   && <a href={SOCIAL.threads}   target="_blank" rel="noopener">Threads</a>}
        </div>
      )}
      <div class="row">
        <div class="info">
          📍 {ADDRESS}<br />
          <a class="maplink" href={MAP_URL} target="_blank" rel="noopener">在 Google 地圖開啟 →</a>
          <div class="cta">
            <a class="btn btn-pri" href={BOOK_URL} target="_blank" rel="noopener">立即預約</a>
            <a class="btn btn-line" href={LINE_URL} target="_blank" rel="noopener">LINE 諮詢</a>
          </div>
        </div>
        <div class="info">
營業時間<br />週一～週日 10:00–21:00<br />
          （採預約制，敬請事先預約）
        </div>
      </div>
      <div class="copyright">© {new Date().getFullYear()} I'm here 有我在療癒所</div>
    </div>
  </footer>

  <!-- 手機固定預約列 -->
  <div class="bookbar">
    <a class="btn btn-line" href={LINE_URL} target="_blank" rel="noopener">LINE 諮詢</a>
    <a class="btn btn-pri" href={BOOK_URL} target="_blank" rel="noopener">立即預約</a>
  </div>
</Layout>
