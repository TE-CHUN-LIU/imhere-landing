---
import Layout from "../layouts/Layout.astro";
import Assessment from "../components/Assessment";
import { SERVICES, BOOK_URL, LINE_URL, MAP_URL, ADDRESS, TRAINING_FORM_URL, TRAINING, SOCIAL, EVENTS } from "../data/services";

// 見證牆（方向 F：精煉短引文 + masonry）
const voices = [
  { tag: "個人頌缽", text: "缽在身上磨，好舒服，震動震到身體很裡面。身體越來越鬆，突然被自己的打呼聲嚇醒，太舒服太感謝老師了！" },
  { tag: "個人頌缽", text: "一開始思緒很混亂，透過一次次的缽聲把我帶回當下，我才意識到頭腦多麼 overload。我沒想過，專注自己是這麼爽的一件事！" },
  { tag: "雙人頌缽", text: "那天回家很快就睡著，隔天居然沒聽到鬧鐘聲。後來精神好很多，開會也比較專注，謝謝 Here，下個月會再回訪。" },
  { tag: "團體頌缽", text: "那個聲音從耳朵慢慢進到身體裡，好像有什麼被輕輕梳理，不知不覺就睡著了。醒來後肩膀放鬆了、呼吸變深，整個人變得很輕。" },
  { tag: "希塔療癒", text: "謝謝 Here 老師溫暖的引導，那一刻我知道我終於擁抱到內在那個小女孩，胸口那塊石頭終於瓦解。" },
  { tag: "希塔療癒", text: "我不再執著那些讓自己不舒服的關係，也開始踏出舒適圈。這是我第三次來，謝謝 Here 伴著我成長。" },
];

const skills = ["尼泊爾傳統頌缽聲療", "歐美聲音療癒", "臼井靈氣療癒", "冥想引導", "希塔療癒"];

const faqs = [
  { q: "需要穿什麼服裝？", a: "建議穿著舒適、放鬆的服裝即可。過程中多以躺姿或坐姿進行，讓身體能自在放鬆最重要。" },
  { q: "需要特別準備什麼嗎？", a: "不需要特別準備。體驗前請避免過度飲酒或空腹，建議療癒前一小時用餐完畢；並預留一些時間讓自己放慢步調，帶著輕鬆的心情前來即可。" },
  { q: "體驗過程中會睡著嗎？", a: "非常有可能 ☺️ 許多人放鬆後會自然進入休息或半睡半醒的狀態，這是很正常的反應。無論清醒或睡著，都不會影響體驗的進行。" },
  { q: "不知道自己適合哪一項怎麼辦？", a: "沒關係，這是很常見的問題。你可以先做上面的 3 分鐘自評，或透過 LINE 跟我聊聊近期的身心狀態，我會依你的需求協助推薦適合的服務。" },
  { q: "可以線上進行嗎？", a: "希塔療癒與靈氣療癒可線上進行；頌缽聲療因需要實際的聲音與身體振動，採現場體驗。" },
  { q: "孕婦可以參加嗎？", a: "懷孕期間是否適合，會依孕期狀況與服務內容有所不同。建議預約前先與我們聯繫討論，再依你的情況提供適合的建議。" },
  { q: "怎麼前往？在哪裡？", a: "本館位於桃園市大園區致祥一街 95 號 2 樓，距桃園高鐵站步行約 8 分鐘，建議搭乘高鐵或開車前往。詳細位置可點頁面下方的 Google 地圖。" },
  { q: "身體狀況提醒（預約前請主動告知）", a: "若有以下情況請務必於預約前主動告知：懷孕中（尤其前三個月）、有癲癇病史、近期接受手術（術後六個月內）、體內有植入式醫療器材或金屬物（如心律調節器、鋼釘等）、正在接受重大疾病治療。如有健康疑慮，建議先諮詢您的醫療專業人員。" },
];

// 結構化資料（SEO/GEO）：商家 + FAQ + 服務目錄 + 培訓
const SITE = "https://imhere-landing.vercel.app";
const sameAs = [SOCIAL.instagram, SOCIAL.facebook, LINE_URL, MAP_URL].filter(Boolean);
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "HealthAndBeautyBusiness",
      "@id": SITE + "/#business",
      "name": "I'm here 有我在療癒所",
      "url": SITE + "/",
      "image": SITE + "/photos/hero1.jpg",
      "description": "桃園高鐵的頌缽聲療、希塔療癒、靈氣療癒空間，由 Here 老師帶領，陪你在忙碌生活中好好休息、找回身心平衡。",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "致祥一街95號2樓",
        "addressLocality": "大園區",
        "addressRegion": "桃園市",
        "postalCode": "337",
        "addressCountry": "TW",
      },
      "geo": { "@type": "GeoCoordinates", "latitude": 25.0080646, "longitude": 121.2118375 },
      "hasMap": MAP_URL,
      "areaServed": "桃園市",
      "priceRange": "$$",
      "openingHoursSpecification": [{
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
        "opens": "10:00",
        "closes": "21:00",
      }],
      "sameAs": sameAs,
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "療癒服務",
        "itemListElement": SERVICES.map((s) => ({
          "@type": "Offer",
          "itemOffered": { "@type": "Service", "name": s.name, "description": `${s.desc}（${s.price}）`, "keywords": [...s.keywords, ...s.seoKeywords].join("、") },
        })),
      },
    },
    {
      "@type": "FAQPage",
      "@id": SITE + "/#faq",
      "mainEntity": faqs.map((f) => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a },
      })),
    },
    {
      "@type": "Course",
      "name": "專業音療師培訓",
      "description": TRAINING.intro,
      "provider": { "@id": SITE + "/#business" },
    },
  ],
};

// SEO／GEO：彙整全部服務的長尾關鍵字（核心＋長尾，去重）
const metaKeywords = [...new Set(
  SERVICES.flatMap((s) => [...s.keywords, ...s.seoKeywords]).concat([
    "桃園高鐵療癒", "桃園身心靈", "有我在療癒所",
  ])
)].join("、");
---

<Layout keywords={metaKeywords}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- 側邊浮動社群列（捲到哪都看得到，引流社群） -->
  <div class="social-rail" aria-label="社群連結">
    <a href={LINE_URL} target="_blank" rel="noopener" aria-label="LINE 官方帳號">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3.2c-5.06 0-9.18 3.34-9.18 7.45 0 3.68 3.27 6.77 7.68 7.35.3.06.71.2.81.46.09.24.06.6.03.84l-.13.78c-.04.24-.19.93.82.51 1-.42 5.4-3.18 7.36-5.44 1.36-1.49 2.01-3 2.01-4.5C21.4 6.54 17.06 3.2 12 3.2zM8.3 12.86H6.49a.48.48 0 0 1-.48-.48V8.76a.48.48 0 0 1 .96 0v3.14H8.3a.48.48 0 0 1 0 .96zm1.88-.48a.48.48 0 0 1-.96 0V8.76a.48.48 0 0 1 .96 0v3.62zm4.36 0a.48.48 0 0 1-.33.46.5.5 0 0 1-.15.02.48.48 0 0 1-.39-.19l-1.85-2.52v2.23a.48.48 0 0 1-.96 0V8.76a.48.48 0 0 1 .33-.45.48.48 0 0 1 .54.16l1.85 2.52V8.76a.48.48 0 0 1 .96 0v3.62zm3.06-2.29a.48.48 0 0 1 0 .96h-1.33v.85h1.33a.48.48 0 0 1 0 .96h-1.81a.48.48 0 0 1-.48-.48V8.76a.48.48 0 0 1 .48-.48h1.81a.48.48 0 0 1 0 .96h-1.33v.85h1.33z"/></svg>
    </a>
    {SOCIAL.facebook && (
      <a href={SOCIAL.facebook} target="_blank" rel="noopener" aria-label="Facebook">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M13.5 21v-8h2.7l.4-3.13h-3.1V7.88c0-.9.25-1.52 1.55-1.52h1.66V3.56c-.29-.04-1.27-.12-2.42-.12-2.4 0-4.04 1.46-4.04 4.15v2.31H7.55V13h2.7v8z"/></svg>
      </a>
    )}
    {SOCIAL.instagram && (
      <a href={SOCIAL.instagram} target="_blank" rel="noopener" aria-label="Instagram">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 9.1a2.9 2.9 0 1 0 0 5.8 2.9 2.9 0 0 0 0-5.8m0 4.78a1.88 1.88 0 1 1 0-3.76 1.88 1.88 0 0 1 0 3.76m3.68-4.9a.68.68 0 1 1-1.36 0 .68.68 0 0 1 1.36 0M17.6 9a3.36 3.36 0 0 0-.92-2.38A3.38 3.38 0 0 0 14.3 5.7c-.94-.05-3.76-.05-4.7 0a3.37 3.37 0 0 0-2.38.92A3.36 3.36 0 0 0 6.3 9c-.05.94-.05 3.76 0 4.7.04.94.28 1.77.92 2.38.64.64 1.44.88 2.38.92.94.05 3.76.05 4.7 0a3.36 3.36 0 0 0 2.38-.92c.64-.61.88-1.44.92-2.38.05-.94.05-3.76 0-4.7m-1.2 5.7a1.9 1.9 0 0 1-1.07 1.07c-.74.3-2.5.23-3.33.23s-2.59.07-3.33-.23a1.9 1.9 0 0 1-1.07-1.07c-.3-.74-.23-2.5-.23-3.33s-.07-2.59.23-3.33A1.9 1.9 0 0 1 8.67 7.3c.74-.3 2.5-.23 3.33-.23s2.59-.07 3.33.23a1.9 1.9 0 0 1 1.07 1.07c.3.74.23 2.5.23 3.33s.07 2.59-.23 3.33"/></svg>
      </a>
    )}
    {SOCIAL.youtube && (
      <a href={SOCIAL.youtube} target="_blank" rel="noopener" aria-label="YouTube">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21.6 7.2s-.19-1.36-.78-1.96c-.75-.79-1.59-.79-1.97-.84C16.05 4.2 12 4.2 12 4.2h-.01s-4.04 0-6.84.2c-.39.05-1.22.05-1.97.84-.6.6-.78 1.96-.78 1.96S2.2 8.8 2.2 10.4v1.5c0 1.6.2 3.2.2 3.2s.19 1.36.78 1.96c.75.79 1.74.76 2.18.85 1.58.15 6.64.2 6.64.2s4.05-.01 6.85-.21c.38-.05 1.22-.05 1.97-.84.59-.6.78-1.96.78-1.96s.2-1.6.2-3.2v-1.5c0-1.6-.2-3.2-.2-3.2M9.75 13.9V8.62l5.2 2.65z"/></svg>
      </a>
    )}
  </div>

  <!-- NAV -->
  <nav class="topnav">
    <div class="bar">
      <a class="nv-brand" href="#top">I&apos;m here</a>
      <div class="nv-links">
        <a href="#assess">自評</a>
        <a href="#services">服務</a>
        <a href="#training">培訓</a>
        <a href="#events">活動</a>
        <a href="#voices">見證</a>
        <a href="#faq">FAQ</a>
        <a class="nv-book btn btn-pri" href={BOOK_URL} target="_blank" rel="noopener">預約</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <header class="hero" id="top">
    <div class="hero-grid">
      <div class="hero-copy">
        <div class="sub latin">breathe, you are held here</div>
        <h1>給忙碌生活中的你，一段被好好照顧的時間</h1>
        <p class="desc">桃園高鐵・頌缽聲療・希塔療癒・靈氣療癒<br />Here 老師帶領，3 分鐘自評，找到最適合你的療癒。</p>
        <div class="cta">
          <a class="btn btn-dark" href="#assess">3 分鐘，找到適合我的療癒</a>
          <a class="btn btn-ghost" href={BOOK_URL} target="_blank" rel="noopener">立即預約</a>
        </div>
      </div>
      <figure class="hero-photo">
        <img src="/photos/hero1.jpg" alt="有我在療癒所療癒空間與頌缽聲療情境" data-zoom />
      </figure>
    </div>
  </header>

  <!-- ASSESSMENT -->
  <section id="assess" class="sec">
    <div class="wrap narrow">
      <div class="head">
        <span class="eyebrow">Self Check</span>
        <h2 class="sec-title">先聽聽你的身體，<br />想被怎麼照顧</h2>
        <p class="lead assess-lead">拉動下面 10 個感受，看看此刻最適合的療癒方式，沒有對錯，只是陪自己停下來、感覺自己</p>
      </div>
      <Assessment client:load />
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" class="sec">
    <div class="wrap">
      <div class="head">
        <span class="eyebrow">Treatments</span>
        <h2 class="sec-title">三種陪伴身心的方式</h2>
      </div>
      <div class="svc-list">
        {SERVICES.map((s, i) => (
          <article class={`svc${i % 2 === 1 ? " flip" : ""}`}>
            <div class="ph"><img src={s.photo} alt={`${s.name}體驗｜有我在療癒所 桃園高鐵`} loading="lazy" data-zoom /></div>
            <div class="txt">
              <div class="num latin">{s.num}</div>
              <h3>{s.name}</h3>
              <p class="desc">{s.desc}</p>
              <p class="keywords"><span class="kw-icon">👉</span>關鍵字：{s.keywords.join("・")}</p>
              <ul class="chips">{s.chips.map((c) => <li>{c}</li>)}</ul>
              <div class="price">
                <div class="price-time">
                  <span class="price-kicker latin">Time</span>
                  <span>{s.pricing.time}</span>
                </div>
                <div class="price-items">
                  {s.pricing.items.map((item) => (
                    <div class="price-item">
                      <span>{item.label}</span>
                      <strong>{item.value}</strong>
                    </div>
                  ))}
                </div>
                {s.pricing.extra && <div class="price-extra">{s.pricing.extra}</div>}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- TRAINING -->
  <section id="training" class="sec alt">
    <div class="wrap">
      <div class="head">
        <span class="eyebrow">Training</span>
        <h2 class="sec-title">專業音療師培訓</h2>
        <p class="lead">{TRAINING.intro}</p>
      </div>
      <div class="tiers">
        {TRAINING.levels.map((lv) => (
          <article class="tier">
            <div class="num latin">{lv.num}</div>
            <div class="stage">{lv.stage}</div>
            <div class="sub">{lv.sub}</div>
            <div class="tgoal">{lv.goal}</div>
            <ul class="tpoints">{lv.points.map((p) => <li>{p}</li>)}</ul>
            <div class="tprice">{lv.price}</div>
          </article>
        ))}
      </div>
      <div class="combo">
        <div class="ct">{TRAINING.combo.title}</div>
        <div class="clead">{TRAINING.combo.lead}</div>
        <div class="cprice">{TRAINING.combo.price}</div>
        <div class="cn">{TRAINING.combo.orig}　{TRAINING.combo.save}</div>
        <div class="cperks">
          <span class="cperks-lbl">並獲得</span>
          <ul>{TRAINING.combo.perks.map((p) => <li>{p}</li>)}</ul>
        </div>
      </div>
      <div class="t-cta">
        <a class="btn btn-dark" href={TRAINING_FORM_URL} target="_blank" rel="noopener">我要報名 / 索取課程資訊</a>
        <a class="btn btn-text" href={LINE_URL} target="_blank" rel="noopener">加 LINE 問梯次時間 →</a>
      </div>
      <p class="tnote">{TRAINING.note}</p>
    </div>
  </section>

  <!-- EVENTS -->
  <section id="events" class="sec">
    <div class="wrap">
      <div class="head">
        <span class="eyebrow">Events</span>
        <h2 class="sec-title">主題活動</h2>
      </div>
      <div class="events">
        {EVENTS.map((e) => (
          <div class="event">
            <div class="when latin">{e.date} <span>（{e.day}）</span></div>
            <h3>{e.name}</h3>
            <div class="emeta">{e.time} ・ {e.price}</div>
            <a class="btn btn-acc" href={e.url} target="_blank" rel="noopener">報名</a>
          </div>
        ))}
        <div class="event follow">
          <div class="ftxt">更多場次與最新消息</div>
          <a href={LINE_URL} target="_blank" rel="noopener">在 LINE 關注 🤍</a>
        </div>
      </div>
    </div>
  </section>

  <!-- VOICES -->
  <section id="voices" class="sec alt">
    <div class="wrap">
      <div class="head">
        <span class="eyebrow">Voices</span>
        <h2 class="sec-title">他們在這裡，重新好好呼吸</h2>
      </div>
      <div class="voices">
        {voices.map((v) => (
          <div class="quote">
            <div class="tag">{v.tag}</div>
            <p>{v.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="sec">
    <div class="wrap about">
      <div class="ph"><img src="/photos/owner.jpg" alt="Here 老師 — 有我在療癒所 聲音療癒師" loading="lazy" data-zoom /></div>
      <div>
        <span class="eyebrow">About</span>
        <h2>Here</h2>
        <div class="role">聲音療癒師 · 身心放鬆帶領者</div>
        <div class="skills">{skills.map((s) => <span>{s}</span>)}</div>
        <p class="pull">「希望透過聲音與陪伴，讓每個人都能在忙碌生活中，找到屬於自己的安定與平衡。」</p>
        <p class="bio">曾任職大型企業超過 10 年，因親身經歷身心失衡而踏上療癒之路。2024 年於桃園高鐵成立「有我在療癒所」，陪伴許多人在忙碌的生活中，重新找回放鬆與內在平衡。</p>
        <div class="stats">
          <div><div class="n">1,000+</div><div class="l">累積服務人次</div></div>
          <div><div class="n">10 年</div><div class="l">企業職涯轉身</div></div>
          <div><div class="n">2024</div><div class="l">I&apos;m here 有我在療癒所成立</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="sec alt">
    <div class="wrap narrow">
      <div class="head">
        <span class="eyebrow">FAQ</span>
        <h2 class="sec-title">預約前，你可能想知道</h2>
      </div>
      <div class="faq">
        {faqs.map((f, i) => (
          <details name="faq" open={i === 0}>
            <summary>{f.q}</summary>
            <div class="ans">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="foot sec">
    <div class="wrap">
      <div class="cols">
        <div>
          <div class="brand">I&apos;m here</div>
          <div class="since">有我在療癒所 · since 2024</div>
          {(SOCIAL.instagram || SOCIAL.facebook || SOCIAL.threads) && (
            <div class="social">
              {SOCIAL.instagram && <a href={SOCIAL.instagram} target="_blank" rel="noopener">Instagram</a>}
              {SOCIAL.facebook  && <a href={SOCIAL.facebook}  target="_blank" rel="noopener">Facebook</a>}
              {SOCIAL.threads   && <a href={SOCIAL.threads}   target="_blank" rel="noopener">Threads</a>}
            </div>
          )}
        </div>
        <div>
          <div class="lbl">地點</div>
          <p class="info">{ADDRESS}</p>
          <a class="maplink" href={MAP_URL} target="_blank" rel="noopener">在 Google 地圖開啟 →</a>
          <p class="geo-line">位於桃園高鐵（青埔）特區，提供桃園頌缽聲療、希塔療癒、靈氣療癒，是桃園地區身心放鬆與能量療癒的推薦選擇。</p>
        </div>
        <div>
          <div class="lbl">營業時間</div>
          <p class="info">週一～週日 10:00–21:00<br />（採預約制，敬請事先預約）</p>
        </div>
      </div>
      <div class="fcta">
        <a class="btn btn-pri" href={BOOK_URL} target="_blank" rel="noopener">立即預約</a>
        <a class="btn btn-ghost" href={LINE_URL} target="_blank" rel="noopener">LINE 諮詢</a>
      </div>
      <div class="copyright">© 2024 I&apos;m here 有我在療癒所</div>
    </div>
  </footer>

