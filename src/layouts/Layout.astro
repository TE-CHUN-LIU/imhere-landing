---
import "../styles/global.css";
interface Props { title?: string; description?: string; keywords?: string; }
const {
  title = "I'm here 有我在療癒所｜頌缽聲療・希塔・靈氣療癒｜桃園高鐵",
  description = "給忙碌生活中的你，一段被好好照顧的時間。桃園高鐵頌缽聲療、希塔療癒、靈氣療癒，Here 老師帶領。3 分鐘自評，找到最適合你的療癒。",
  keywords,
} = Astro.props;
const site = Astro.site ?? new URL("https://imhere-landing.vercel.app");
const ogImage = new URL("/photos/hero1.jpg", site).href;
const canonical = new URL(Astro.url.pathname, site).href;
---
<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <script is:inline>document.documentElement.classList.add("js-reveal");</script>
    <meta name="google-site-verification" content="8msN6fRifnF36NuAtDvxhpF1IA8LDIaf7Bsh-2DbL1I" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:site_name" content="I'm here 有我在療癒所" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1800" />
    <meta property="og:image:height" content="1350" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="theme-color" content="#FBF6EF" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=Noto+Sans+TC:wght@200;300;400;500&family=Noto+Serif+TC:wght@200;300;400;500;600&display=swap"
    />
  </head>
  <body>
    <slot />

    <!-- 自訂游標（桌機）＋ 圖片放大 lightbox -->
    <div class="cursor" aria-hidden="true">
      <div class="cursor-ring"></div>
      <div class="cursor-dot"></div>
      <div class="cursor-label">放大</div>
    </div>
    <div class="lightbox" role="dialog" aria-modal="true" aria-label="圖片放大檢視">
      <button class="lb-close" type="button" aria-label="關閉">✕</button>
      <img src="" alt="" />
    </div>
    <script is:inline>
      (function () {
        if (!window.matchMedia || !window.matchMedia("(prefers-reduced-motion: no-preference)").matches) return;
        var SEL = ".head,.hero .sub,.hero h1,.hero .desc,.hero .cta,.hero-photo,.svc,.tier,.combo,.event,.quote,.about .ph,.about .role,.about .pull,.about .bio,.about .stats,#faq details";
        var els = [].slice.call(document.querySelectorAll(SEL));
        var seen = new Map();
        els.forEach(function (el) {
          var p = el.parentElement;
          var i = seen.get(p) || 0;
          el.style.transitionDelay = Math.min(i, 6) * 70 + "ms";
          seen.set(p, i + 1);
        });
        if (!("IntersectionObserver" in window)) {
          els.forEach(function (el) { el.classList.add("is-in"); });
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) { e.target.classList.add("is-in"); io.unobserve(e.target); }
          });
        }, { rootMargin: "0px 0px -8% 0px", threshold: 0.12 });
        els.forEach(function (el) { io.observe(el); });
      })();
    </script>
    <script is:inline>
      (function () {
        // 圖片放大 lightbox（所有裝置）
        var lb = document.querySelector(".lightbox");
        var lbImg = lb && lb.querySelector("img");
        function openLB(src, alt) {
          if (!lb) return;
          lbImg.src = src; lbImg.alt = alt || "";
          lb.classList.add("open"); document.body.classList.add("lb-on"); document.body.style.overflow = "hidden";
        }
        function closeLB() {
          if (!lb) return;
          lb.classList.remove("open"); document.body.classList.remove("lb-on"); document.body.style.overflow = "";
          setTimeout(function () { lbImg.src = ""; }, 250);
        }
        document.querySelectorAll("[data-zoom]").forEach(function (img) {
          img.addEventListener("click", function () { openLB(img.currentSrc || img.src, img.alt); });
        });
        if (lb) lb.addEventListener("click", closeLB);
        document.addEventListener("keydown", function (e) { if (e.key === "Escape") closeLB(); });

        // 自訂游標（僅桌機、有精準指標）
        if (!window.matchMedia || !window.matchMedia("(hover: hover) and (pointer: fine)").matches) return;
        var cur = document.querySelector(".cursor");
        if (!cur) return;
        document.documentElement.classList.add("js-cursor");
        var reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        var x = window.innerWidth / 2, y = window.innerHeight / 2, rx = x, ry = y;
        document.addEventListener("mousemove", function (e) {
          x = e.clientX; y = e.clientY; cur.style.opacity = "1";
          if (reduce) { cur.style.transform = "translate(" + x + "px," + y + "px)"; }
        });
        if (!reduce) {
          (function loop() {
            rx += (x - rx) * 0.2; ry += (y - ry) * 0.2;
            cur.style.transform = "translate(" + rx + "px," + ry + "px)";
            requestAnimationFrame(loop);
          })();
        }
        document.addEventListener("mouseover", function (e) {
          var z = e.target.closest("[data-zoom]");
          var h = e.target.closest("a,button,input,[role=button],summary");
          cur.classList.toggle("is-zoom", !!z);
          cur.classList.toggle("is-hover", !!h && !z);
        });
        document.addEventListener("mouseout", function (e) {
          if (!e.relatedTarget) cur.classList.remove("is-zoom", "is-hover");
        });
        document.documentElement.addEventListener("mouseleave", function () { cur.style.opacity = "0"; });
      })();
    </script>
  </body>
</html>
