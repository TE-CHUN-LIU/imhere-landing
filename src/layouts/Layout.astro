---
import "../styles/global.css";
interface Props { title?: string; description?: string; keywords?: string; }
const {
  title = "I'm here 有我在療癒所 頌缽｜靈氣｜希塔｜水晶飾品",
  description = "給忙碌生活中的你，一段被好好照顧的時間。桃園高鐵頌缽聲療、希塔療癒、靈氣療癒，Here 老師帶領。3 分鐘自評，找到最適合你的療癒。",
  keywords,
} = Astro.props;
const site = Astro.site ?? new URL("https://im-here-healingspace.com");
const ogImage = new URL("/photos/hero1.jpg", site).href;
const canonical = new URL(Astro.url.pathname, site).href;
---
<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <script is:inline>document.documentElement.classList.add("js-reveal");</script>
    <meta name="google-site-verification" content="8msN6fRifnF36NuAtDvxhpF1IA8LDIaf7Bsh-2DbL1I" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:site_name" content="I'm here 有我在療癒所" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1800" />
    <meta property="og:image:height" content="1350" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="theme-color" content="#FBF6EF" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=Noto+Sans+TC:wght@200;300;400;500&family=Noto+Serif+TC:wght@200;300;400;500;600&display=swap"
    />
  </head>
  <body>
    <slot />

    <!-- 自訂游標（桌機）＋ 圖片放大 lightbox -->
    <div class="cursor" aria-hidden="true">
      <div class="cursor-ring"></div>
      <div class="cursor-dot"></div>
      <div class="cursor-label">放大</div>
    </div>
    <div class="lightbox" role="dialog" aria-modal="true" aria-label="圖片放大檢視">
      <button class="lb-close" type="button" aria-label="關閉">✕</button>
      <img src="" alt="" />
    </div>
    <script is:inline>
      (function () {
        if (!window.matchMedia || !window.matchMedia("(prefers-reduced-motion: no-preference)").matches) return;
        var SEL = ".head,.svc,.tier,.combo,.event,.quote,.about .ph,.about .role,.about .pull,.about .bio,.about .stats,#faq details";
        var els = [].slice.call(document.querySelectorAll(SEL));
        var seen = new Map();
        els.forEach(function (el) {
          var p = el.parentElement;
          var i = seen.get(p) || 0;
          el.style.transitionDelay = Math.min(i, 6) * 70 + "ms";
          seen.set(p, i + 1);
        });
        if (!("IntersectionObserver" in window)) {
          els.forEach(function (el) { el.classList.add("is-in"); });
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) { e.target.classList.add("is-in"); io.unobserve(e.target); }
          });
        }, { rootMargin: "0px 0px -8% 0px", threshold: 0.12 });
        els.forEach(function (el) { io.observe(el); });
      })();
    </script>
    <script is:inline>
      (function () {
        // 圖片放大 lightbox（所有裝置）
        var lb = document.querySelector(".lightbox");
        var lbImg = lb && lb.querySelector("img");
        function openLB(src, alt) {
          if (!lb) return;
          lbImg.src = src; lbImg.alt = alt || "";
          lb.classList.add("open"); document.body.classList.add("lb-on"); document.body.style.overflow = "hidden";
        }
        function closeLB() {
          if (!lb) return;
          lb.classList.remove("open"); document.body.classList.remove("lb-on"); document.body.style.overflow = "";
          setTimeout(function () { lbImg.src = ""; }, 250);
        }
        document.querySelectorAll("[data-zoom]").forEach(function (img) {
          img.addEventListener("click", function () { openLB(img.currentSrc || img.src, img.alt); });
        });
        if (lb) lb.addEventListener("click", closeLB);
        document.addEventListener("keydown", function (e) { if (e.key === "Escape") closeLB(); });

        // 自訂游標（僅桌機、有精準指標）
        if (!window.matchMedia || !window.matchMedia("(hover: hover) and (pointer: fine)").matches) return;
        var cur = document.querySelector(".cursor");
        if (!cur) return;
        document.documentElement.classList.add("js-cursor");
        var reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        var x = window.innerWidth / 2, y = window.innerHeight / 2, rx = x, ry = y;
        document.addEventListener("mousemove", function (e) {
          x = e.clientX; y = e.clientY; cur.style.opacity = "1";
          if (reduce) { cur.style.transform = "translate(" + x + "px," + y + "px)"; }
        });
        if (!reduce) {
          (function loop() {
            rx += (x - rx) * 0.2; ry += (y - ry) * 0.2;
            cur.style.transform = "translate(" + rx + "px," + ry + "px)";
            requestAnimationFrame(loop);
          })();
        }
        document.addEventListener("mouseover", function (e) {
          var z = e.target.closest("[data-zoom]");
          var h = e.target.closest("a,button,input,[role=button],summary");
          cur.classList.toggle("is-zoom", !!z);
          cur.classList.toggle("is-hover", !!h && !z);
        });
        document.addEventListener("mouseout", function (e) {
          if (!e.relatedTarget) cur.classList.remove("is-zoom", "is-hover");
        });
        document.documentElement.addEventListener("mouseleave", function () { cur.style.opacity = "0"; });
      })();
    </script>

    <!-- GSAP 招牌動畫：Hero 進場時間軸 + 背景視差 + 磁吸 CTA + 數字計數。
         其餘區塊維持上方 IntersectionObserver reveal，兩者互不干擾。 -->
    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      const reduce =
        window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const hero = document.querySelector(".hero");

      if (!reduce && hero) {
        gsap.registerPlugin(ScrollTrigger);

        // 1) Hero 進場時間軸
        const seq = [".hero .sub", ".hero h1", ".hero .desc", ".hero .cta", ".hero-photo"]
          .map((s) => hero.querySelector(s))
          .filter(Boolean);
        gsap.set(seq, { opacity: 0, y: 26 });
        gsap.to(seq, {
          opacity: 1,
          y: 0,
          duration: 1.1,
          ease: "power3.out",
          stagger: 0.14,
          delay: 0.15,
        });

        // 2) Hero 圖視差
        const photo = hero.querySelector(".hero-photo");
        const photoImg = hero.querySelector(".hero-photo img");
        if (photo && photoImg) {
          (photo as HTMLElement).style.overflow = "hidden";
          gsap.set(photoImg, { scale: 1.12, transformOrigin: "center center" });
          gsap.fromTo(
            photoImg,
            { yPercent: -6 },
            {
              yPercent: 6,
              ease: "none",
              scrollTrigger: { trigger: hero, start: "top top", end: "bottom top", scrub: true },
            }
          );
        }

        // 3) 磁吸 CTA（僅桌機精準指標）
        const fine =
          window.matchMedia && window.matchMedia("(hover: hover) and (pointer: fine)").matches;
        const btn = hero.querySelector<HTMLElement>(".hero .cta .btn-dark");
        if (fine && btn) {
          const strength = 0.3;
          btn.addEventListener("mousemove", (e) => {
            const r = btn.getBoundingClientRect();
            gsap.to(btn, {
              x: (e.clientX - (r.left + r.width / 2)) * strength,
              y: (e.clientY - (r.top + r.height / 2)) * strength,
              duration: 0.4,
              ease: "power3.out",
            });
          });
          btn.addEventListener("mouseleave", () => {
            gsap.to(btn, { x: 0, y: 0, duration: 0.5, ease: "elastic.out(1, 0.4)" });
          });
        }
      }

      // 4) 數字跳動計數（.about .stats .n），滾到才觸發；減少動態時維持原值
      if (!reduce) {
        gsap.registerPlugin(ScrollTrigger);
        document.querySelectorAll<HTMLElement>(".about .stats .n").forEach((el) => {
          const raw = (el.textContent || "").trim();
          const m = raw.match(/^([\d,]+)(.*)$/); // 前導數字（含千分位）+ 後綴，如 "1,000+"、"10 年"
          if (!m) return;
          const target = parseInt(m[1].replace(/,/g, ""), 10);
          const suffix = m[2];
          if (!Number.isFinite(target)) return;
          const useComma = m[1].includes(",");
          const counter = { v: 0 };
          gsap.to(counter, {
            v: target,
            duration: 1.4,
            ease: "power2.out",
            scrollTrigger: { trigger: el, start: "top 85%", once: true },
            onUpdate: () => {
              const n = Math.round(counter.v);
              el.textContent = (useComma ? n.toLocaleString("en-US") : String(n)) + suffix;
            },
          });
        });
      }
    </script>
  </body>
</html>
